---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = "La app de matemáticas que convierte el estudio en una aventura." } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --bg: #0a0015;
      --bg2: #11001f;
      --bg3: #1a0033;
      --purple: #7B2FBE;
      --purple2: #9B4FD8;
      --lavender: #CC88FF;
      --gold: #FFD700;
      --gold2: #FFF0A0;
      --text: #e8e0f0;
      --muted: #9966CC;
      --dimmed: #4B0082;
      --correct: #00AA66;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Crimson Pro', Georgia, serif;
      font-size: 18px;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── Stars ── */
    #stars { position: fixed; inset: 0; pointer-events: none; z-index: 0; }

    /* ── NAV ── */
    .site-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 40px;
      background: rgba(10,0,21,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(123,47,190,0.2);
    }
    .nav-logo {
      font-family: 'Cinzel', serif; font-size: 1.3rem; font-weight: 900;
      letter-spacing: 0.15em; color: var(--gold); text-decoration: none;
    }
    .nav-logo span { color: var(--lavender); }
    .nav-links { display: flex; gap: 32px; list-style: none; }
    .nav-links a {
      color: var(--muted); font-size: 0.95rem; letter-spacing: 0.05em;
      text-decoration: none; transition: color 0.2s; font-family: 'Cinzel', serif;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-cta {
      background: var(--gold); color: #1a0033; font-family: 'Cinzel', serif;
      font-weight: 700; font-size: 0.85rem; letter-spacing: 0.1em;
      padding: 10px 22px; border-radius: 30px; text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 0 20px rgba(255,215,0,0.3);
    }
    .nav-cta:hover { transform: translateY(-2px); box-shadow: 0 0 32px rgba(255,215,0,0.5); }

    /* ── FOOTER ── */
    .site-footer {
      position: relative; z-index: 1;
      border-top: 1px solid rgba(123,47,190,0.15);
      padding: 20px 40px;
      display: flex; align-items: center; justify-content: space-between; gap: 16px;
    }
    .footer-logo {
      font-family: 'Cinzel', serif; font-size: 1rem; font-weight: 900;
      letter-spacing: 0.18em; color: var(--gold); text-decoration: none; white-space: nowrap;
    }
    .footer-logo span { color: var(--lavender); }
    .footer-copy {
      color: var(--dimmed); font-size: 0.8rem; letter-spacing: 0.04em;
      text-align: center; flex: 1; white-space: nowrap;
    }
    .footer-nav { display: flex; gap: 28px; list-style: none; align-items: center; }
    .footer-nav a {
      color: var(--muted); font-size: 0.78rem; text-decoration: none;
      font-family: 'Cinzel', serif; letter-spacing: 0.07em;
      transition: color 0.2s; white-space: nowrap;
    }
    .footer-nav a:hover { color: var(--gold); }
    .footer-nav a.legal { color: var(--purple2); }
    .footer-nav a.legal:hover { color: var(--lavender); }

    /* ── LEGAL PAGES NAV ── */
    .legal-nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 40px;
      background: rgba(10,0,21,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(123,47,190,0.2);
    }
    .nav-back {
      color: var(--muted); font-family: 'Cinzel', serif;
      font-size: 0.85rem; letter-spacing: 0.05em;
      text-decoration: none; transition: color 0.2s;
    }
    .nav-back:hover { color: var(--gold); }

    /* ── LEGAL CONTENT ── */
    .page-hero {
      background: linear-gradient(180deg, rgba(26,0,51,0.8) 0%, transparent 100%);
      padding: 80px 24px 60px; text-align: center;
    }
    .page-tag {
      font-family: 'Cinzel', serif; font-size: 0.7rem;
      letter-spacing: 0.3em; color: var(--dimmed); margin-bottom: 14px;
    }
    .page-title {
      font-family: 'Cinzel', serif; font-size: clamp(2rem,5vw,3.2rem);
      font-weight: 700; color: var(--gold); margin-bottom: 14px;
    }
    .page-meta { color: var(--muted); font-size: 0.95rem; font-style: italic; }
    .doc-wrap { max-width: 780px; margin: 0 auto; padding: 20px 24px 100px; }
    .doc-section { margin-bottom: 52px; }
    .doc-wrap h2 {
      font-family: 'Cinzel', serif; font-size: 1.25rem; font-weight: 700;
      color: var(--lavender); margin-bottom: 16px; padding-bottom: 10px;
      border-bottom: 1px solid rgba(123,47,190,0.2);
    }
    .doc-wrap p { color: var(--text); margin-bottom: 14px; }
    .doc-wrap ul { margin: 12px 0 14px 24px; }
    .doc-wrap ul li { color: var(--text); margin-bottom: 8px; }
    .doc-wrap strong { color: var(--gold); font-weight: 600; }
    .highlight-box {
      background: rgba(26,0,51,0.7); border: 1px solid rgba(123,47,190,0.3);
      border-left: 3px solid var(--purple); border-radius: 0 12px 12px 0;
      padding: 18px 22px; margin: 20px 0;
    }
    .highlight-box p { margin: 0; }
    .contact-box {
      background: rgba(26,0,51,0.7); border: 1px solid rgba(255,215,0,0.2);
      border-radius: 16px; padding: 28px; margin-top: 40px;
    }
    .contact-box h3 {
      font-family: 'Cinzel', serif; font-size: 1rem; color: var(--gold); margin-bottom: 12px;
    }
    .contact-box a { color: var(--lavender); }
    .plan-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 24px 0; }
    .plan-box {
      background: rgba(26,0,51,0.6); border: 1px solid rgba(123,47,190,0.25);
      border-radius: 16px; padding: 24px 20px;
    }
    .plan-box.gold-border { border-color: rgba(255,215,0,0.3); }
    .plan-box h3 {
      font-family: 'Cinzel', serif; font-size: 1rem; font-weight: 700;
      color: var(--gold); margin-bottom: 12px;
    }
    .plan-box ul { margin-left: 16px; }
    .plan-box li { font-size: 0.92rem; color: var(--muted); margin-bottom: 6px; }

    @media (max-width: 900px) {
      .site-footer { flex-direction: column; text-align: center; padding: 28px 24px; gap: 14px; }
      .footer-nav { flex-wrap: wrap; justify-content: center; }
      .plan-compare { grid-template-columns: 1fr; }
    }
    @media (max-width: 700px) {
      .site-nav { padding: 14px 20px; }
      .nav-links { display: none; }
      .legal-nav { padding: 14px 20px; }
    }
  </style>
</head>
<body>
  <canvas id="stars"></canvas>
  <slot />
  <script>
    const canvas = document.getElementById('stars') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    let stars: {x:number;y:number;r:number;speed:number;phase:number}[] = [];
    function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
    function init() {
      stars = [];
      for (let i = 0; i < 160; i++) {
        stars.push({ x: Math.random()*canvas.width, y: Math.random()*canvas.height, r: Math.random()*1.5+0.3, speed: Math.random()*0.008+0.002, phase: Math.random()*Math.PI*2 });
      }
    }
    function draw(t: number) {
      ctx.clearRect(0,0,canvas.width,canvas.height);
      stars.forEach(s => {
        const a = 0.3 + 0.5 * Math.sin(t * s.speed + s.phase);
        ctx.beginPath(); ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
        ctx.fillStyle = `rgba(255,215,0,${a})`; ctx.fill();
      });
      requestAnimationFrame(draw);
    }
    resize(); init(); requestAnimationFrame(draw);
    window.addEventListener('resize', () => { resize(); init(); });
  </script>
</body>
</html>